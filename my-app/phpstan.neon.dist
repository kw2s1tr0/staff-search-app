includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - routes
        - tests
    ignoreErrors:
        -
            path: tests/Unit/ExampleTest.php
            message: '#Call to method PHPUnit\\Framework\\Assert::assertTrue\(\) with true will always evaluate to true\.#'
