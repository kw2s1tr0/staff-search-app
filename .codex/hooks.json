{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash /ssapp/.codex/hooks/session_start.sh",
            "statusMessage": "Loading repository guidance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /ssapp/.codex/hooks/pre_tool_use.sh",
            "statusMessage": "Checking command policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /ssapp/.codex/hooks/post_tool_use.sh",
            "statusMessage": "Recording command result"
          }
        ]
      }
    ]
  }
}
